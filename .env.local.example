# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Better Auth ──────────────────────────────────────────────────────────────
# Generate a 32-char secret: `openssl rand -hex 32`
BETTER_AUTH_SECRET=your_secret_here_min_32_characters

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# DATABASE_URL = Supabase Session Pooler connection string
# Found in: Supabase Dashboard → Settings → Database → Connection string (Session mode)
DATABASE_URL=postgresql://postgres.your-project-id:password@aws-0-ap-south-1.pooler.supabase.com:5432/postgres

# ─── Cloudflare R2 (optional — for vendor document uploads) ───────────────────
# Found in: Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=stonamart-vendor-docs
# Public R2 bucket URL (if you've enabled public access)
NEXT_PUBLIC_R2_PUBLIC_URL=https://pub-xxxx.r2.dev
